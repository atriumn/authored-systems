---
import Base from './Base.astro';

interface Props {
  title: string;
  subtitle?: string;
  date: string;
  description?: string;
}

const { title, subtitle, date, description } = Astro.props;
const formattedDate = new Date(date + 'T00:00:00').toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Base title={`${title} — authored.systems`} description={description}>
  <article class="max-w-3xl mx-auto px-6 py-16">
    <header class="mb-12">
      <div class="flex items-start justify-between gap-4">
        <div>
          <time class="text-sm font-mono text-muted block mb-4">{formattedDate}</time>
          <h1 class="text-3xl sm:text-4xl font-semibold tracking-tight leading-tight">{title}</h1>
          {subtitle && <p class="text-lg text-muted mt-3">{subtitle}</p>}
        </div>
        <button
          id="copy-page"
          class="shrink-0 mt-1 text-muted hover:text-ink transition-colors p-2 rounded-md hover:bg-rule/50"
          aria-label="Copy page as markdown"
          title="Copy page as markdown"
        >
          <svg id="copy-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
          </svg>
          <svg id="check-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden text-accent">
            <polyline points="20 6 9 17 4 12"></polyline>
          </svg>
        </button>
      </div>
    </header>
    <div id="prose-content" class="prose prose-lg max-w-none">
      <slot />
    </div>
  </article>

  <script define:vars={{ title, subtitle, formattedDate }}>
    document.getElementById('copy-page')?.addEventListener('click', () => {
      const prose = document.getElementById('prose-content');
      if (!prose) return;

      // Build markdown from the prose content
      let md = `# ${title}\n`;
      if (subtitle) md += `> ${subtitle}\n`;
      md += `${formattedDate}\n\n`;

      // Walk the DOM and convert to markdown
      md += htmlToMarkdown(prose);

      navigator.clipboard.writeText(md).then(() => {
        const copyIcon = document.getElementById('copy-icon');
        const checkIcon = document.getElementById('check-icon');
        copyIcon?.classList.add('hidden');
        checkIcon?.classList.remove('hidden');
        setTimeout(() => {
          copyIcon?.classList.remove('hidden');
          checkIcon?.classList.add('hidden');
        }, 2000);
      });
    });

    function htmlToMarkdown(el) {
      let result = '';
      for (const node of el.childNodes) {
        if (node.nodeType === Node.TEXT_NODE) {
          result += node.textContent;
        } else if (node.nodeType === Node.ELEMENT_NODE) {
          const tag = node.tagName.toLowerCase();
          if (tag === 'h2') {
            result += `\n## ${node.textContent.trim()}\n\n`;
          } else if (tag === 'h3') {
            result += `\n### ${node.textContent.trim()}\n\n`;
          } else if (tag === 'h4') {
            result += `\n#### ${node.textContent.trim()}\n\n`;
          } else if (tag === 'p') {
            result += `${inlineMarkdown(node)}\n\n`;
          } else if (tag === 'blockquote') {
            const text = node.textContent.trim();
            result += `> ${text}\n\n`;
          } else if (tag === 'ul') {
            for (const li of node.querySelectorAll(':scope > li')) {
              result += `- ${inlineMarkdown(li).trim()}\n`;
            }
            result += '\n';
          } else if (tag === 'ol') {
            let i = 1;
            for (const li of node.querySelectorAll(':scope > li')) {
              result += `${i}. ${inlineMarkdown(li).trim()}\n`;
              i++;
            }
            result += '\n';
          } else if (tag === 'pre') {
            const code = node.querySelector('code');
            result += `\`\`\`\n${code ? code.textContent : node.textContent}\`\`\`\n\n`;
          } else if (tag === 'hr') {
            result += `---\n\n`;
          } else if (tag === 'table') {
            result += tableToMarkdown(node) + '\n\n';
          } else {
            result += htmlToMarkdown(node);
          }
        }
      }
      return result;
    }

    function inlineMarkdown(el) {
      let result = '';
      for (const node of el.childNodes) {
        if (node.nodeType === Node.TEXT_NODE) {
          result += node.textContent;
        } else if (node.nodeType === Node.ELEMENT_NODE) {
          const tag = node.tagName.toLowerCase();
          if (tag === 'strong' || tag === 'b') {
            result += `**${node.textContent}**`;
          } else if (tag === 'em' || tag === 'i') {
            result += `*${node.textContent}*`;
          } else if (tag === 'code') {
            result += `\`${node.textContent}\``;
          } else if (tag === 'a') {
            result += `[${node.textContent}](${node.getAttribute('href')})`;
          } else {
            result += inlineMarkdown(node);
          }
        }
      }
      return result;
    }

    function tableToMarkdown(table) {
      const rows = [];
      for (const tr of table.querySelectorAll('tr')) {
        const cells = [];
        for (const cell of tr.querySelectorAll('th, td')) {
          cells.push(cell.textContent.trim());
        }
        rows.push(cells);
      }
      if (rows.length === 0) return '';
      let md = '| ' + rows[0].join(' | ') + ' |\n';
      md += '| ' + rows[0].map(() => '---').join(' | ') + ' |\n';
      for (let i = 1; i < rows.length; i++) {
        md += '| ' + rows[i].join(' | ') + ' |\n';
      }
      return md;
    }
  </script>
</Base>
