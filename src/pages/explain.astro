---
import Base from '../layouts/Base.astro';
---

<Base title="How It Works — authored.systems" description="Watch an operation come to life, one primitive at a time.">
  <div class="explain">
    <!-- Sticky graphic -->
    <div class="graphic">
      <div id="industry-pills" class="industry-pills hidden">
        <button class="pill active" data-industry="property">Property</button>
        <button class="pill" data-industry="restaurant">Restaurant</button>
        <button class="pill" data-industry="saas">SaaS</button>
        <button class="pill" data-industry="construction">Construction</button>
      </div>
      <svg id="diagram" viewBox="0 0 800 500" xmlns="http://www.w3.org/2000/svg">
        <!-- Layout:
             Event(150,100) -> Policy(400,100) -> Procedure(650,100)
                                                       |
             Ledger(150,400) <- Asset(400,400) <- Person(650,400)
             Ledger feeds back to Event (left side, up)
        -->

        <!-- Connecting paths (hidden initially, revealed per-step) -->
        <line id="path-event-policy" x1="200" y1="100" x2="350" y2="100" stroke="#e5e5e3" stroke-width="2" opacity="0" />
        <line id="path-policy-procedure" x1="450" y1="100" x2="600" y2="100" stroke="#e5e5e3" stroke-width="2" opacity="0" />
        <line id="path-procedure-person" x1="650" y1="150" x2="650" y2="350" stroke="#e5e5e3" stroke-width="2" opacity="0" />
        <line id="path-person-asset" x1="600" y1="400" x2="450" y2="400" stroke="#e5e5e3" stroke-width="2" opacity="0" />
        <line id="path-asset-ledger" x1="350" y1="400" x2="200" y2="400" stroke="#e5e5e3" stroke-width="2" opacity="0" />

        <!-- Chevron arrows on paths -->
        <polygon id="arrow-1" points="345,95 355,100 345,105" fill="#e5e5e3" opacity="0" />
        <polygon id="arrow-2" points="595,95 605,100 595,105" fill="#e5e5e3" opacity="0" />
        <polygon id="arrow-3" points="645,345 650,355 655,345" fill="#e5e5e3" opacity="0" />
        <polygon id="arrow-4" points="455,395 445,400 455,405" fill="#e5e5e3" opacity="0" />
        <polygon id="arrow-5" points="205,395 195,400 205,405" fill="#e5e5e3" opacity="0" />

        <!-- Event node — lightning bolt in circle -->
        <g id="node-event" class="node" opacity="0">
          <circle cx="150" cy="100" r="44" fill="#fafaf8" stroke="#1a1a1a" stroke-width="2" />
          <path d="M148,76 L140,100 L150,98 L144,124 L160,94 L149,96 Z" fill="none" stroke="#1a1a1a" stroke-width="1.5" stroke-linejoin="round" />
          <text x="150" y="158" text-anchor="middle" font-family="Inter, system-ui, sans-serif" font-size="13" font-weight="600" fill="#1a1a1a">Event</text>
        </g>

        <!-- Policy node — document with lines -->
        <g id="node-policy" class="node" opacity="0">
          <rect x="358" y="60" width="84" height="80" rx="6" fill="#fafaf8" stroke="#1a1a1a" stroke-width="2" />
          <!-- Dog-ear fold -->
          <path d="M422,60 L422,72 L442,72" fill="#fafaf8" stroke="#1a1a1a" stroke-width="1.5" />
          <!-- Rule lines -->
          <line x1="372" y1="84" x2="428" y2="84" stroke="#1a1a1a" stroke-width="1" opacity="0.4" />
          <line x1="372" y1="94" x2="420" y2="94" stroke="#1a1a1a" stroke-width="1" opacity="0.4" />
          <line x1="372" y1="104" x2="424" y2="104" stroke="#1a1a1a" stroke-width="1" opacity="0.4" />
          <line x1="372" y1="114" x2="412" y2="114" stroke="#1a1a1a" stroke-width="1" opacity="0.4" />
          <text x="400" y="158" text-anchor="middle" font-family="Inter, system-ui, sans-serif" font-size="13" font-weight="600" fill="#1a1a1a">Policy</text>
        </g>

        <!-- Procedure node — checklist with checkboxes -->
        <g id="node-procedure" class="node" opacity="0">
          <rect x="608" y="60" width="84" height="80" rx="6" fill="#fafaf8" stroke="#1a1a1a" stroke-width="2" />
          <!-- Checkbox rows -->
          <rect x="620" y="76" width="10" height="10" rx="2" fill="none" stroke="#1a1a1a" stroke-width="1.2" />
          <path d="M622,81 L624,84 L629,78" fill="none" stroke="#1a1a1a" stroke-width="1.2" />
          <line x1="636" y1="82" x2="678" y2="82" stroke="#1a1a1a" stroke-width="1" opacity="0.4" />
          <rect x="620" y="94" width="10" height="10" rx="2" fill="none" stroke="#1a1a1a" stroke-width="1.2" />
          <path d="M622,99 L624,102 L629,96" fill="none" stroke="#1a1a1a" stroke-width="1.2" />
          <line x1="636" y1="100" x2="678" y2="100" stroke="#1a1a1a" stroke-width="1" opacity="0.4" />
          <rect x="620" y="112" width="10" height="10" rx="2" fill="none" stroke="#1a1a1a" stroke-width="1.2" />
          <line x1="636" y1="118" x2="678" y2="118" stroke="#1a1a1a" stroke-width="1" opacity="0.4" />
          <text x="650" y="158" text-anchor="middle" font-family="Inter, system-ui, sans-serif" font-size="13" font-weight="600" fill="#1a1a1a">Procedure</text>
        </g>

        <!-- Person node — bust silhouette -->
        <g id="node-person" class="node" opacity="0">
          <circle cx="650" cy="400" r="44" fill="#fafaf8" stroke="#1a1a1a" stroke-width="2" />
          <!-- Head -->
          <circle cx="650" cy="388" r="10" fill="none" stroke="#1a1a1a" stroke-width="1.5" />
          <!-- Shoulders -->
          <path d="M634,416 Q634,404 650,404 Q666,404 666,416" fill="none" stroke="#1a1a1a" stroke-width="1.5" />
          <text x="650" y="458" text-anchor="middle" font-family="Inter, system-ui, sans-serif" font-size="13" font-weight="600" fill="#1a1a1a">Person</text>
        </g>

        <!-- Extra person nodes for optimization (step 9) — row at y=400 -->
        <g id="node-person-b" class="node" opacity="0">
          <circle cx="540" cy="400" r="30" fill="#fafaf8" stroke="#1a1a1a" stroke-width="1.5" />
          <circle cx="540" cy="392" r="6" fill="none" stroke="#1a1a1a" stroke-width="1.2" />
          <path d="M530,412 Q530,404 540,404 Q550,404 550,412" fill="none" stroke="#1a1a1a" stroke-width="1.2" />
          <text x="540" y="440" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="8" fill="#6b6b6b">4.2 / 8mi</text>
        </g>
        <g id="node-person-c" class="node" opacity="0">
          <circle cx="760" cy="400" r="30" fill="#fafaf8" stroke="#1a1a1a" stroke-width="1.5" />
          <circle cx="760" cy="392" r="6" fill="none" stroke="#1a1a1a" stroke-width="1.2" />
          <path d="M750,412 Q750,404 760,404 Q770,404 770,412" fill="none" stroke="#1a1a1a" stroke-width="1.2" />
          <text x="760" y="440" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="8" fill="#6b6b6b">3.9 / 14mi</text>
        </g>

        <!-- Asset node — rounded box with tag -->
        <g id="node-asset" class="node" opacity="0">
          <rect x="356" y="368" width="88" height="64" rx="12" fill="#fafaf8" stroke="#1a1a1a" stroke-width="2" />
          <!-- ID tag line -->
          <line x1="376" y1="388" x2="424" y2="388" stroke="#1a1a1a" stroke-width="1" opacity="0.4" />
          <!-- Barcode-like hash marks -->
          <line x1="382" y1="400" x2="382" y2="414" stroke="#1a1a1a" stroke-width="1.5" opacity="0.3" />
          <line x1="388" y1="400" x2="388" y2="414" stroke="#1a1a1a" stroke-width="2.5" opacity="0.3" />
          <line x1="394" y1="400" x2="394" y2="414" stroke="#1a1a1a" stroke-width="1" opacity="0.3" />
          <line x1="399" y1="400" x2="399" y2="414" stroke="#1a1a1a" stroke-width="2" opacity="0.3" />
          <line x1="405" y1="400" x2="405" y2="414" stroke="#1a1a1a" stroke-width="1.5" opacity="0.3" />
          <line x1="411" y1="400" x2="411" y2="414" stroke="#1a1a1a" stroke-width="1" opacity="0.3" />
          <line x1="417" y1="400" x2="417" y2="414" stroke="#1a1a1a" stroke-width="2" opacity="0.3" />
          <text x="400" y="458" text-anchor="middle" font-family="Inter, system-ui, sans-serif" font-size="13" font-weight="600" fill="#1a1a1a">Asset</text>
        </g>

        <!-- Ledger node — open book / stacked rows -->
        <g id="node-ledger" class="node" opacity="0">
          <rect x="108" y="368" width="84" height="64" rx="4" fill="#fafaf8" stroke="#1a1a1a" stroke-width="2" />
          <!-- Spine -->
          <line x1="150" y1="368" x2="150" y2="432" stroke="#1a1a1a" stroke-width="1.5" />
          <!-- Left page lines -->
          <line x1="118" y1="382" x2="144" y2="382" stroke="#1a1a1a" stroke-width="1" opacity="0.3" />
          <line x1="118" y1="392" x2="144" y2="392" stroke="#1a1a1a" stroke-width="1" opacity="0.3" />
          <line x1="118" y1="402" x2="144" y2="402" stroke="#1a1a1a" stroke-width="1" opacity="0.3" />
          <line x1="118" y1="412" x2="140" y2="412" stroke="#1a1a1a" stroke-width="1" opacity="0.3" />
          <!-- Right page lines -->
          <line x1="156" y1="382" x2="182" y2="382" stroke="#1a1a1a" stroke-width="1" opacity="0.3" />
          <line x1="156" y1="392" x2="182" y2="392" stroke="#1a1a1a" stroke-width="1" opacity="0.3" />
          <line x1="156" y1="402" x2="182" y2="402" stroke="#1a1a1a" stroke-width="1" opacity="0.3" />
          <line x1="156" y1="412" x2="178" y2="412" stroke="#1a1a1a" stroke-width="1" opacity="0.3" />
          <text x="150" y="458" text-anchor="middle" font-family="Inter, system-ui, sans-serif" font-size="13" font-weight="600" fill="#1a1a1a">Ledger</text>
        </g>

        <!-- Messy-input overlay -->
        <g id="chaos-flood" opacity="0">
          <circle cx="150" cy="100" r="76" fill="#ef4444" opacity="0.05" class="chaos-pulse" />
          <circle cx="150" cy="100" r="58" fill="#f97316" opacity="0.06" class="chaos-pulse" />

          <!-- Noisy inbound signal lines -->
          <line x1="20" y1="52" x2="118" y2="86" stroke="#dc2626" stroke-width="2" stroke-dasharray="3 4" opacity="0.5" class="chaos-drift" />
          <line x1="26" y1="96" x2="108" y2="100" stroke="#ea580c" stroke-width="2" stroke-dasharray="2 5" opacity="0.45" class="chaos-drift" />
          <line x1="24" y1="148" x2="116" y2="116" stroke="#dc2626" stroke-width="2" stroke-dasharray="4 4" opacity="0.45" class="chaos-drift" />

          <!-- Source cards -->
          <g class="chaos-drift">
            <rect x="4" y="34" width="76" height="22" rx="6" fill="#fff7ed" stroke="#fdba74" />
            <text x="42" y="48" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="8" fill="#9a3412">email</text>
          </g>
          <g class="chaos-drift">
            <rect x="2" y="88" width="82" height="22" rx="6" fill="#fff7ed" stroke="#fdba74" />
            <text x="43" y="102" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="8" fill="#9a3412">voice note</text>
          </g>
          <g class="chaos-drift">
            <rect x="6" y="142" width="72" height="22" rx="6" fill="#fff7ed" stroke="#fdba74" />
            <text x="42" y="156" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="8" fill="#9a3412">photo</text>
          </g>

          <!-- Ambiguous fragments -->
          <text x="228" y="62" font-family="JetBrains Mono, monospace" font-size="9" fill="#b91c1c" opacity="0.6" class="chaos-drift">unclear location</text>
          <text x="214" y="84" font-family="JetBrains Mono, monospace" font-size="9" fill="#b91c1c" opacity="0.6" class="chaos-drift">missing severity</text>
        </g>

        <!-- AI perception gateway -->
        <g id="ai-filter" opacity="0">
          <rect x="76" y="44" width="46" height="112" rx="8" fill="#eff6ff" stroke="#60a5fa" stroke-width="1.5" />
          <rect x="82" y="52" width="34" height="96" rx="6" fill="#dbeafe" opacity="0.65" />
          <line x1="88" y1="70" x2="110" y2="70" stroke="#2563eb" stroke-width="1.2" opacity="0.7" />
          <line x1="88" y1="80" x2="110" y2="80" stroke="#2563eb" stroke-width="1.2" opacity="0.7" />
          <line x1="88" y1="90" x2="110" y2="90" stroke="#2563eb" stroke-width="1.2" opacity="0.7" />
          <line x1="88" y1="108" x2="110" y2="108" stroke="#2563eb" stroke-width="1.2" opacity="0.7" />
          <line x1="88" y1="118" x2="110" y2="118" stroke="#2563eb" stroke-width="1.2" opacity="0.7" />
          <line x1="88" y1="128" x2="110" y2="128" stroke="#2563eb" stroke-width="1.2" opacity="0.7" />
          <text x="99" y="38" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="8" font-weight="700" fill="#1d4ed8">AI PARSER</text>
        </g>

        <!-- AI optimization: underline + BEST MATCH badge (step 9) -->
        <g id="ai-opt-highlight" opacity="0">
          <rect id="ai-sweep-bar" x="530" y="440" width="0" height="3" rx="1.5" fill="#2563eb" opacity="0.5" />
          <rect x="620" y="448" width="60" height="16" rx="3" fill="#2563eb" opacity="0" id="ai-best-badge-bg" />
          <text id="ai-best-label" x="650" y="460" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="8" font-weight="700" fill="#fff" opacity="0">BEST MATCH</text>
        </g>

        <!-- AI pattern detection: ledger scan lines (step 10) -->
        <g id="ai-ledger-lines" opacity="0">
          <line x1="120" y1="385" x2="180" y2="385" stroke="#2563eb" stroke-width="1.5" opacity="0" class="ledger-scan-line" />
          <line x1="125" y1="392" x2="175" y2="392" stroke="#2563eb" stroke-width="1.5" opacity="0" class="ledger-scan-line" />
          <line x1="122" y1="399" x2="178" y2="399" stroke="#2563eb" stroke-width="1.5" opacity="0" class="ledger-scan-line" />
          <line x1="128" y1="406" x2="172" y2="406" stroke="#2563eb" stroke-width="1.5" opacity="0" class="ledger-scan-line" />
          <line x1="124" y1="413" x2="176" y2="413" stroke="#2563eb" stroke-width="1.5" opacity="0" class="ledger-scan-line" />
        </g>
        <!-- Horizontal dashed line from Ledger to Policy (step 10) -->
        <line id="ai-pattern-line" x1="200" y1="300" x2="370" y2="300" stroke="#2563eb" stroke-width="2" stroke-dasharray="6 3" fill="none" opacity="0" />
        <text id="ai-pattern-label" x="285" y="318" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="9" fill="#2563eb" opacity="0">pattern → suggest rule update</text>

        <!-- Final state: AI text labels at three edge points (step 11) -->
        <g id="ai-edge-labels" opacity="0">
          <text x="100" y="56" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="9" font-weight="600" fill="#2563eb">AI</text>
          <text x="650" y="345" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="9" font-weight="600" fill="#2563eb">AI</text>
          <text x="150" y="340" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="9" font-weight="600" fill="#2563eb">AI</text>
        </g>

        <!-- Step 0: Blue AI blob — the promise: vague, attractive, shapeless. Not wrong, just premature. -->
        <g id="ai-blob" opacity="0">
          <circle cx="400" cy="250" r="80" fill="#2563eb" opacity="0.15" />
          <circle cx="400" cy="250" r="60" fill="#2563eb" opacity="0.25" />
          <circle cx="400" cy="250" r="36" fill="#2563eb" opacity="0.4" />
          <text x="400" y="255" text-anchor="middle" font-family="Inter, system-ui, sans-serif" font-size="20" font-weight="700" fill="#fff">AI</text>
          <!-- Messy unlabeled arrows in/out -->
          <line x1="260" y1="180" x2="348" y2="222" stroke="#2563eb" stroke-width="2" opacity="0.45" />
          <line x1="280" y1="330" x2="352" y2="280" stroke="#2563eb" stroke-width="2" opacity="0.45" />
          <line x1="520" y1="170" x2="450" y2="220" stroke="#2563eb" stroke-width="2" opacity="0.45" />
          <line x1="540" y1="310" x2="452" y2="272" stroke="#2563eb" stroke-width="2" opacity="0.45" />
          <line x1="400" y1="120" x2="400" y2="192" stroke="#2563eb" stroke-width="2" opacity="0.45" />
          <line x1="400" y1="380" x2="400" y2="308" stroke="#2563eb" stroke-width="2" opacity="0.45" />
          <!-- Small labels on arrows -->
          <text x="235" y="172" font-family="JetBrains Mono, monospace" font-size="11" font-weight="600" fill="#2563eb" opacity="0.75">INPUTS?</text>
          <text x="245" y="344" font-family="JetBrains Mono, monospace" font-size="11" font-weight="600" fill="#2563eb" opacity="0.75">OWNERS?</text>
          <text x="522" y="162" font-family="JetBrains Mono, monospace" font-size="11" font-weight="600" fill="#2563eb" opacity="0.75">DATA?</text>
          <text x="530" y="326" font-family="JetBrains Mono, monospace" font-size="11" font-weight="600" fill="#2563eb" opacity="0.75">RULES?</text>
        </g>

        <!-- Step 0 intent caption -->
        <g id="ai-blob-caption" opacity="0">
          <rect x="220" y="34" width="360" height="72" rx="8" fill="#fafaf8" stroke="#bfdbfe" stroke-width="1.5" />
          <text x="400" y="58" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="11" font-weight="700" fill="#2563eb">
            UNSTRUCTURED AI ARCHITECTURE
          </text>
          <text x="400" y="76" text-anchor="middle" font-family="Inter, system-ui, sans-serif" font-size="11.5" fill="#1a1a1a">
            Everything goes in. Decisions come out.
          </text>
          <text x="400" y="91" text-anchor="middle" font-family="Inter, system-ui, sans-serif" font-size="11.5" fill="#1a1a1a">
            Control and accountability are unclear.
          </text>
        </g>

        <!-- Step 12: Side-by-side comparison -->
        <g id="comparison" opacity="0">
          <!-- Left side: blue AI blob (no structure) -->
          <text x="200" y="50" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="14" font-weight="600" fill="#2563eb">AI AS OPERATOR</text>
          <circle cx="200" cy="200" r="70" fill="#2563eb" opacity="0.12" />
          <circle cx="200" cy="200" r="50" fill="#2563eb" opacity="0.2" />
          <circle cx="200" cy="200" r="28" fill="#2563eb" opacity="0.35" />
          <text x="200" y="205" text-anchor="middle" font-family="Inter, system-ui, sans-serif" font-size="16" font-weight="700" fill="#fff">AI</text>
          <!-- Chaos arrows -->
          <line x1="130" y1="140" x2="172" y2="176" stroke="#2563eb" stroke-width="1" opacity="0.3" />
          <line x1="130" y1="260" x2="175" y2="228" stroke="#2563eb" stroke-width="1" opacity="0.3" />
          <line x1="270" y1="140" x2="228" y2="176" stroke="#2563eb" stroke-width="1" opacity="0.3" />
          <line x1="270" y1="260" x2="225" y2="228" stroke="#2563eb" stroke-width="1" opacity="0.3" />
          <!-- Generic AI model labels -->
          <text x="200" y="293" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="9" fill="#6b6b6b">single decision maker</text>
          <text x="200" y="315" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="11" fill="#6b6b6b">rules hidden in prompts</text>
          <text x="200" y="335" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="11" fill="#6b6b6b">hard to audit</text>
          <!-- Contrast labels -->
          <text x="200" y="370" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="11" fill="#6b6b6b">postmortems are weak</text>
          <text x="200" y="387" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="11" fill="#6b6b6b">ownership is unclear</text>
          <text x="200" y="404" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="11" fill="#6b6b6b">model behavior = policy</text>
          <text x="200" y="421" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="11" fill="#6b6b6b">fragile under stress</text>

          <!-- Divider -->
          <line x1="400" y1="70" x2="400" y2="460" stroke="#e5e5e3" stroke-width="1" stroke-dasharray="4 4" />

          <!-- Right side: authored system miniature (1.5x scale) -->
          <text x="600" y="50" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="14" font-weight="600" fill="#1a1a1a">AUTHORED SYSTEM + AI</text>
          <!-- Mini primitives loop — scaled up -->
          <circle cx="510" cy="150" r="24" fill="#fafaf8" stroke="#1a1a1a" stroke-width="1.5" />
          <text x="510" y="154" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="9" fill="#1a1a1a">EVT</text>
          <rect x="571" y="126" width="48" height="48" rx="4" fill="#fafaf8" stroke="#1a1a1a" stroke-width="1.5" />
          <text x="595" y="154" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="9" fill="#1a1a1a">POL</text>
          <rect x="656" y="126" width="48" height="48" rx="4" fill="#fafaf8" stroke="#1a1a1a" stroke-width="1.5" />
          <text x="680" y="154" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="9" fill="#1a1a1a">PRC</text>
          <circle cx="680" cy="270" r="24" fill="#fafaf8" stroke="#1a1a1a" stroke-width="1.5" />
          <text x="680" y="274" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="9" fill="#1a1a1a">PER</text>
          <rect x="571" y="246" width="48" height="48" rx="8" fill="#fafaf8" stroke="#1a1a1a" stroke-width="1.5" />
          <text x="595" y="274" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="9" fill="#1a1a1a">AST</text>
