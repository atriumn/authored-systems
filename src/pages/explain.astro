        2: {
          structured: 'Policy: cold food = remake + manager touch in 5 minutes. Procedure: refire, expo verify, runner deliver.',
        },
        3: {
          structured: 'Assigned to certified grill cook; table and ticket linked as assets.',
          outcome: 'Ledger entry: remake sent 6:12pm, comp applied, guest recovered.',
        },
        4: {
          input: 'Yelp post with photo and vague comment: "again, cold food."',
        },
        5: {
          structured: 'AI output: issue=cold steak, table=12, time=7:45pm, severity=medium.',
          outcome: 'Event routed to service recovery workflow with context.',
        },
        6: {
          structured: 'Eligible cooks: 2. AI ranks by station load and current queue.',
          outcome: 'Lower-load cook chosen to cut recovery time.',
        },
        7: {
          structured: 'Ledger cohort signal: steak remakes spike 40% on Friday 7–9pm when grill wait >14 minutes.',
          outcome: 'Policy suggestion: open a second grill lane when wait-time threshold is crossed.',
        },
        8: {
          structured: 'Audit: recovery procedure missing follow-up step for repeat complaints. Food safety cert expires for 2 line cooks in 10 days.',
          outcome: 'Procedure updated with follow-up gate. Certification renewal flagged to manager.',
        },
      },
    },
    saas: {
      label: 'SaaS',
      examples: {
        1: {
          input: 'Staging deploy fails after config push.',
          outcome: 'Incident channel opens and rollback path is activated.',
        },
        2: {
          structured: 'Policy: failed deploy => auto-rollback + page on-call. Procedure: rollback, verify, patch, redeploy.',
        },
        3: {
          structured: 'Assigned to on-call engineer familiar with auth service; service is linked asset.',
          outcome: 'Ledger entry: rollback at 03:14 UTC, MTTR 22m, cause=config drift.',
        },
        4: {
          input: 'Slack noise: "site feels slow, maybe auth?"',
        },
        5: {
          structured: 'AI output: correlated alerts => auth latency spike, p95 > 2s, confidence high.',
          outcome: 'Structured incident routes to the right playbook.',
        },
        6: {
          structured: 'Eligible responders: 3. AI ranks by service familiarity + active incident load.',
          outcome: 'Primary + backup selected automatically.',
        },
        7: {
          structured: 'Ledger trend: config-drift incidents cluster within 24 hours of emergency patch releases.',
          outcome: 'Policy suggestion: require automated drift reconciliation before merge on patch branches.',
        },
        8: {
          structured: 'Audit: rollback procedure assumes single-region deploy but 2 services are now multi-region. On-call rotation has coverage gap Sundays 2-6am.',
          outcome: 'Procedure flagged for architecture review. Rotation gap escalated to eng manager.',
        },
      },
    },
    construction: {
      label: 'Construction',
      examples: {
        1: {
          input: 'Weather alert triggers concrete pour delay.',
          outcome: 'Schedule-risk ticket opens for superintendent review.',
        },
        2: {
          structured: 'Policy: rain delay => reschedule within 48 hours and notify GC. Procedure: assess, cover, update, notify subs.',
        },
        3: {
          structured: 'Assigned to certified site super; affected foundation section is linked asset.',
          outcome: 'Ledger entry: pour moved to Thursday, materials covered, no waste.',
        },
        4: {
          input: 'Voicemail: "inspector said something about rebar spacing."',
        },
        5: {
          structured: 'AI output: rebar spacing concern, section B, inspection flag present.',
          outcome: 'Issue routed to quality workflow immediately.',
        },
        6: {
          structured: 'Eligible subs: 4. AI ranks by equipment readiness + proximity.',
          outcome: 'Crew selected with least schedule risk.',
        },
        7: {
          structured: 'Ledger cohort signal: rebar spacing flags concentrate on pours from one supplier lot.',
          outcome: 'Policy suggestion: hold that lot, add incoming QC gate, and pre-stage alternate supply.',
        },
        8: {
          structured: 'Audit: wet-weather procedure doesn\'t cover curing requirements for new concrete spec. 1 site super\'s OSHA 30 certification lapsed.',
          outcome: 'Procedure revision drafted for review. Certification hold placed on affected super.',
        },
      },
    },
  };

  let currentIndustry = 'property';
  let currentStep = 0;

  const scroller = scrollama();
  scroller.setup({
    step: '.step',
    offset: 0.5,
  }).onStepEnter(({ index }: { index: number }) => {
    const step = index;
    if (step !== currentStep) {
      currentStep = step;
      updateDiagram(step);
    }
  });

  window.addEventListener('resize', () => scroller.resize());

  function show(id: string, visible: boolean) {
    const el = document.getElementById(id);
    if (el) el.style.opacity = visible ? '1' : '0';
  }

  function setIndustry(key: string) {
    currentIndustry = key;
    document.querySelectorAll('.chooser-btn, .pill').forEach(btn => {
      btn.classList.toggle('active', (btn as HTMLElement).dataset.industry === key);
    });
    renderExamples();
  }

  function renderExamples() {
    document.querySelectorAll<HTMLElement>('[data-step-examples]').forEach(el => {
      const step = Number(el.dataset.stepExamples);
      const industry = industries[currentIndustry];
      const ex = industry?.examples[step];
      if (!ex) return;

      const rows: string[] = [];
      if (ex.input) rows.push(`<div class="example input"><span class="example-label input">${industry.label} Input:</span> ${ex.input}</div>`);
      if (ex.structured) rows.push(`<div class="example structured"><span class="example-label structured">Structured:</span> ${ex.structured}</div>`);
      if (ex.outcome) rows.push(`<div class="example outcome"><span class="example-label outcome">Outcome:</span> ${ex.outcome}</div>`);

      el.innerHTML = rows.join('');
    });
  }

  let dotAnimation: number | null = null;
  let stepTimeouts: ReturnType<typeof setTimeout>[] = [];

  function stopDot() {
    if (dotAnimation) {
      cancelAnimationFrame(dotAnimation);
      dotAnimation = null;
    }
  }

  // Hide all diagram elements to start clean
  function hideAll() {
    // Primitives
    ['node-event', 'node-policy', 'node-procedure', 'node-person', 'node-asset', 'node-ledger'].forEach(id => show(id, false));
    // Paths + arrows
    ['path-event-policy', 'path-policy-procedure', 'path-procedure-person', 'path-person-asset', 'path-asset-ledger'].forEach(id => show(id, false));
    ['arrow-1', 'arrow-2', 'arrow-3', 'arrow-4', 'arrow-5'].forEach(id => show(id, false));
    // Dots
    show('dot', false);
    show('clean-dot', false);
    stopDot();
    // AI announce
    show('ai-announce', false);
    const announceEl = document.getElementById('ai-announce');
    if (announceEl) announceEl.style.transform = 'translate(0,0) scale(1)';
    // AI elements
    show('chaos-flood', false);
    show('ai-filter', false);
    show('node-person-b', false);
    show('node-person-c', false);
    show('ai-opt-highlight', false);
    show('ai-best-label', false);
    show('ai-best-badge-bg', false);
    const sweep = document.getElementById('ai-sweep-bar');
    if (sweep) {
      sweep.setAttribute('width', '0');
      (sweep as HTMLElement).style.transition = 'none';
    }
    show('ai-ledger-lines', false);
    show('ai-pattern-line', false);
    show('ai-pattern-label', false);
    show('ai-edge-labels', false);
    // Reset ledger scan lines
    document.querySelectorAll('.ledger-scan-line').forEach(el => (el as HTMLElement).style.opacity = '0');
    // Clear any pending step timeouts
    stepTimeouts.forEach(t => clearTimeout(t));
    stepTimeouts = [];
    // Bookend elements
    show('ai-blob', false);
    show('ai-blob-caption', false);
    show('comparison', false);
  }

  function announceAI(label: string, targetX: number, targetY: number, callback: () => void) {
    const group = document.getElementById('ai-announce');
    const text = document.getElementById('ai-announce-text');
    if (!group || !text) { callback(); return; }

    text.textContent = label;
    // Reset to center, full size
    group.style.transition = 'none';
    group.style.transform = 'translate(0,0) scale(1)';
    group.style.opacity = '1';
    // Force reflow so the reset takes effect before transition
    group.getBoundingClientRect();

    // After a pause, fly to target
    stepTimeouts.push(setTimeout(() => {
      group.style.transition = 'transform 0.8s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.8s ease';
      const dx = targetX - 400;
      const dy = targetY - 250;
      group.style.transform = `translate(${dx}px, ${dy}px) scale(0.4)`;
      group.style.opacity = '0';
    }, 1200));

    // After fly completes, clean up and run callback
    stepTimeouts.push(setTimeout(() => {
      group.style.transition = 'none';
      group.style.opacity = '0';
      group.style.transform = 'translate(0,0) scale(1)';
      callback();
    }, 2050));
  }

  function updateDiagram(step: number) {
    // Reset everything, then build up
    hideAll();

    // Show/hide sticky industry pills
    const pills = document.getElementById('industry-pills');
    if (pills) pills.classList.toggle('hidden', step === 0 || step >= 9);

    // === Step 0: Blue AI blob opener ===
    if (step === 0) {
      show('ai-blob', true);
      show('ai-blob-caption', true);
      return;
    }

    // === Step 9: Two architectures comparison ===
    if (step === 9) {
      show('comparison', true);
      return;
    }

    // === ACT 1: Core structure (steps 1-3) ===

    // Step 1+: Event
    show('node-event', step >= 1);

    // Static dot at Event for steps 1-2
    if (step >= 1 && step < 3) {
      show('dot', true);
      show('clean-dot', false);
      const dot = document.getElementById('dot');
      if (dot) {
        dot.setAttribute('cx', '150');
        dot.setAttribute('cy', '100');
        dot.setAttribute('fill', '#1a1a1a');
        dot.setAttribute('r', '6');
      }
    }

    // Step 2+: Policy + Procedure
    show('node-policy', step >= 2);
    show('path-event-policy', step >= 2);
    show('arrow-1', step >= 2);
    show('node-procedure', step >= 2);
    show('path-policy-procedure', step >= 2);
    show('arrow-2', step >= 2);

    // Step 3+: Person + Asset + Ledger
    show('node-person', step >= 3);
    show('path-procedure-person', step >= 3);
    show('arrow-3', step >= 3);
    show('node-asset', step >= 3);
    show('path-person-asset', step >= 3);
    show('arrow-4', step >= 3);
    show('node-ledger', step >= 3);
    show('path-asset-ledger', step >= 3);
    show('arrow-5', step >= 3);

    if (step === 3) {
      show('dot', true);
      const dot = document.getElementById('dot');
      if (dot) dot.setAttribute('fill', '#1a1a1a');
      animateDot(false);
    }

    // === ACT 2: AI at the edges (steps 4-7) ===

    // Step 4: Messy input flood
    show('chaos-flood', step === 4);
    if (step === 4) {
      stopDot();
    }

    // Step 5: Perception
    if (step >= 5 && step <= 7 && step !== 5) {
      show('ai-filter', true);
    }
    if (step === 5) {
      announceAI('PERCEPTION', 100, 100, () => {
        show('ai-filter', true);
        show('clean-dot', true);
        animateDot(true);
      });
    }

    // Step 6: Optimization
    if (step === 6) {
      announceAI('OPTIMIZATION', 650, 400, () => {
        show('ai-opt-highlight', true);
        show('clean-dot', true);
        animateDot(true);
        // Stagger: B appears, then main Person, then C
        const pb = document.getElementById('node-person-b');
        const person = document.getElementById('node-person');
        const pc = document.getElementById('node-person-c');
        if (pb) pb.style.opacity = '0';
        if (pc) pc.style.opacity = '0';
        stepTimeouts.push(setTimeout(() => { if (pb) pb.style.opacity = '1'; }, 0));
        stepTimeouts.push(setTimeout(() => { if (person) person.style.opacity = '1'; }, 200));
        stepTimeouts.push(setTimeout(() => { if (pc) pc.style.opacity = '1'; }, 400));
        // After all appear, sweep highlight bar and reveal winner
        stepTimeouts.push(setTimeout(() => {
          const sweep = document.getElementById('ai-sweep-bar');
          if (sweep) {
            sweep.style.transition = 'width 0.5s ease';
            sweep.setAttribute('width', '240');
          }
        }, 800));
        stepTimeouts.push(setTimeout(() => {
          show('ai-best-label', true);
          show('ai-best-badge-bg', true);
          if (pb) pb.style.opacity = '0.3';
          if (pc) pc.style.opacity = '0.3';
        }, 1300));
      });
    } else {
      show('node-person-b', false);
      show('node-person-c', false);
    }

    // Step 7: Pattern detection
    show('ai-ledger-lines', step === 7 || step === 8);
    if (step === 7) {
      announceAI('PATTERN', 150, 400, () => {
        show('clean-dot', true);
        animateDot(true);
        // Stagger ledger scan lines
        const scanLines = document.querySelectorAll('.ledger-scan-line');
        scanLines.forEach((line, i) => {
          stepTimeouts.push(setTimeout(() => {
            (line as HTMLElement).style.opacity = '1';
          }, i * 100));
        });
        // After scanning, show horizontal line and label
        stepTimeouts.push(setTimeout(() => {
          show('ai-pattern-line', true);
          show('ai-pattern-label', true);
        }, scanLines.length * 100 + 200));
      });
      show('ai-filter', true);
      show('ai-edge-labels', true);
    }

    // Step 8: Audit — AI reviews the primitives themselves
    if (step === 8) {
      announceAI('AUDIT', 400, 250, () => {
        show('clean-dot', true);
        show('ai-filter', true);
        show('ai-edge-labels', true);
        show('ai-pattern-line', true);
        show('ai-pattern-label', true);
        // Pulse the policy and procedure nodes to indicate review
        const policy = document.getElementById('node-policy');
        const procedure = document.getElementById('node-procedure');
        if (policy) { policy.style.transition = 'opacity 0.5s'; policy.style.opacity = '1'; }
        if (procedure) { procedure.style.transition = 'opacity 0.5s'; procedure.style.opacity = '1'; }
        // Flash the nodes to indicate active audit
        stepTimeouts.push(setTimeout(() => {
          if (policy) policy.style.opacity = '0.5';
          if (procedure) procedure.style.opacity = '0.5';
        }, 400));
        stepTimeouts.push(setTimeout(() => {
          if (policy) policy.style.opacity = '1';
          if (procedure) procedure.style.opacity = '1';
        }, 800));
      });
    }
  }

  // Easing function: ease-in-out cubic
  function easeInOut(t: number): number {
    return t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2;
  }

  function animateDot(useBlue: boolean) {
    const dotId = useBlue ? 'clean-dot' : 'dot';
    const dot = document.getElementById(dotId);
    if (!dot) return;

    // Hide the other dot
    show(useBlue ? 'dot' : 'clean-dot', false);

    // One pass: Event -> Policy -> Procedure -> Person -> Asset -> Ledger (no loop back)
    const waypoints = [
      { x: 150, y: 100 },  // Event
      { x: 400, y: 100 },  // Policy
      { x: 650, y: 100 },  // Procedure
      { x: 650, y: 400 },  // Person
      { x: 400, y: 400 },  // Asset
      { x: 150, y: 400 },  // Ledger
    ];

    let wpIndex = 0;
    let progress = 0;
    const speed = 0.012;
    const dwellDuration = 18; // frames to dwell at each node (~300ms at 60fps)
    let dwellCounter = 0;
    let isDwelling = false;
    const baseRadius = 6;

    stopDot();

    function frame() {
      if (isDwelling) {
        // Pulse: scale up slightly during dwell
        const dwellProgress = dwellCounter / dwellDuration;
        const pulseScale = 1 + 0.4 * Math.sin(dwellProgress * Math.PI);
        dot.setAttribute('r', String(baseRadius * pulseScale));
        dwellCounter++;
        if (dwellCounter >= dwellDuration) {
          isDwelling = false;
          dwellCounter = 0;
          dot.setAttribute('r', String(baseRadius));
          // Move to next segment or stop at end
          wpIndex++;
          if (wpIndex >= waypoints.length - 1) {
            // Stay at Ledger — don't loop
            return;
          }
          progress = 0;
        }
        dotAnimation = requestAnimationFrame(frame);
        return;
      }

      progress += speed;

      if (progress >= 1) {
        // Snap to waypoint and start dwell
        const target = waypoints[wpIndex + 1] || waypoints[0];
        dot.setAttribute('cx', String(target.x));
        dot.setAttribute('cy', String(target.y));
        progress = 1;
        isDwelling = true;
        dwellCounter = 0;
        dotAnimation = requestAnimationFrame(frame);
        return;
      }

      const from = waypoints[wpIndex];
      const to = waypoints[wpIndex + 1] || waypoints[0];

      // Apply ease-in-out to progress
      const eased = easeInOut(progress);

      const x = from.x + (to.x - from.x) * eased;
      const y = from.y + (to.y - from.y) * eased;

      dot.setAttribute('cx', String(x));
      dot.setAttribute('cy', String(y));

      dotAnimation = requestAnimationFrame(frame);
    }

    frame();
  }

  // Industry switcher event listeners
  document.querySelectorAll<HTMLElement>('[data-industry]').forEach(btn => {
    btn.addEventListener('click', () => {
      if (btn.dataset.industry) setIndustry(btn.dataset.industry);
    });
  });

  // Show step 0 immediately on load (Scrollama doesn't fire until scroll)
  updateDiagram(0);
  renderExamples();
</script>
