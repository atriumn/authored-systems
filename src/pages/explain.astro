---
import Base from '../layouts/Base.astro';
---

<Base title="How It Works — authored.systems" description="Watch an operation come to life, one primitive at a time.">
  <div class="explain">
    <!-- Sticky graphic -->
    <div class="graphic">
      <svg id="diagram" viewBox="0 0 800 500" xmlns="http://www.w3.org/2000/svg">
        <!-- Layout:
             Event(150,100) -> Policy(400,100) -> Procedure(650,100)
                                                       |
             Ledger(150,400) <- Asset(400,400) <- Person(650,400)
             Ledger feeds back to Event (left side, up)
        -->

        <!-- Connecting paths (hidden initially, revealed per-step) -->
        <line id="path-event-policy" x1="200" y1="100" x2="350" y2="100" stroke="#e5e5e3" stroke-width="2" opacity="0" />
        <line id="path-policy-procedure" x1="450" y1="100" x2="600" y2="100" stroke="#e5e5e3" stroke-width="2" opacity="0" />
        <line id="path-procedure-person" x1="650" y1="150" x2="650" y2="350" stroke="#e5e5e3" stroke-width="2" opacity="0" />
        <line id="path-person-asset" x1="600" y1="400" x2="450" y2="400" stroke="#e5e5e3" stroke-width="2" opacity="0" />
        <line id="path-asset-ledger" x1="350" y1="400" x2="200" y2="400" stroke="#e5e5e3" stroke-width="2" opacity="0" />
        <!-- Feedback: Ledger back up to Event -->
        <line id="path-ledger-event" x1="150" y1="350" x2="150" y2="150" stroke="#e5e5e3" stroke-width="2" stroke-dasharray="6 4" opacity="0" />

        <!-- Chevron arrows on paths -->
        <polygon id="arrow-1" points="345,95 355,100 345,105" fill="#e5e5e3" opacity="0" />
        <polygon id="arrow-2" points="595,95 605,100 595,105" fill="#e5e5e3" opacity="0" />
        <polygon id="arrow-3" points="645,345 650,355 655,345" fill="#e5e5e3" opacity="0" />
        <polygon id="arrow-4" points="455,395 445,400 455,405" fill="#e5e5e3" opacity="0" />
        <polygon id="arrow-5" points="205,395 195,400 205,405" fill="#e5e5e3" opacity="0" />
        <polygon id="arrow-6" points="145,155 150,145 155,155" fill="#e5e5e3" opacity="0" />

        <!-- Event node -->
        <g id="node-event" class="node" opacity="0">
          <circle cx="150" cy="100" r="50" fill="#fafaf8" stroke="#1a1a1a" stroke-width="2" />
          <text x="150" y="96" text-anchor="middle" font-family="Inter, system-ui, sans-serif" font-size="14" font-weight="600" fill="#1a1a1a">Event</text>
          <text x="150" y="114" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="10" fill="#6b6b6b">trigger</text>
        </g>

        <!-- Policy node -->
        <g id="node-policy" class="node" opacity="0">
          <circle cx="400" cy="100" r="50" fill="#fafaf8" stroke="#1a1a1a" stroke-width="2" />
          <text x="400" y="96" text-anchor="middle" font-family="Inter, system-ui, sans-serif" font-size="14" font-weight="600" fill="#1a1a1a">Policy</text>
          <text x="400" y="114" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="10" fill="#6b6b6b">rule</text>
        </g>

        <!-- Procedure node -->
        <g id="node-procedure" class="node" opacity="0">
          <circle cx="650" cy="100" r="50" fill="#fafaf8" stroke="#1a1a1a" stroke-width="2" />
          <text x="650" y="96" text-anchor="middle" font-family="Inter, system-ui, sans-serif" font-size="14" font-weight="600" fill="#1a1a1a">Procedure</text>
          <text x="650" y="114" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="10" fill="#6b6b6b">steps</text>
        </g>

        <!-- Person node (main) -->
        <g id="node-person" class="node" opacity="0">
          <circle cx="650" cy="400" r="50" fill="#fafaf8" stroke="#1a1a1a" stroke-width="2" />
          <text x="650" y="396" text-anchor="middle" font-family="Inter, system-ui, sans-serif" font-size="14" font-weight="600" fill="#1a1a1a">Person</text>
          <text x="650" y="414" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="10" fill="#6b6b6b">who</text>
        </g>

        <!-- Extra person nodes for optimization (step 9) -->
        <g id="node-person-b" class="node" opacity="0">
          <circle cx="720" cy="310" r="30" fill="#fafaf8" stroke="#1a1a1a" stroke-width="1.5" />
          <text x="720" y="306" text-anchor="middle" font-family="Inter, system-ui, sans-serif" font-size="10" font-weight="500" fill="#6b6b6b">Person B</text>
          <text x="720" y="320" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="8" fill="#6b6b6b">4.2 / 8mi</text>
        </g>
        <g id="node-person-c" class="node" opacity="0">
          <circle cx="750" cy="400" r="30" fill="#fafaf8" stroke="#1a1a1a" stroke-width="1.5" />
          <text x="750" y="396" text-anchor="middle" font-family="Inter, system-ui, sans-serif" font-size="10" font-weight="500" fill="#6b6b6b">Person C</text>
          <text x="750" y="410" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="8" fill="#6b6b6b">3.9 / 14mi</text>
        </g>

        <!-- Asset node -->
        <g id="node-asset" class="node" opacity="0">
          <circle cx="400" cy="400" r="50" fill="#fafaf8" stroke="#1a1a1a" stroke-width="2" />
          <text x="400" y="396" text-anchor="middle" font-family="Inter, system-ui, sans-serif" font-size="14" font-weight="600" fill="#1a1a1a">Asset</text>
          <text x="400" y="414" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="10" fill="#6b6b6b">thing</text>
        </g>

        <!-- Ledger node -->
        <g id="node-ledger" class="node" opacity="0">
          <circle cx="150" cy="400" r="50" fill="#fafaf8" stroke="#1a1a1a" stroke-width="2" />
          <text x="150" y="396" text-anchor="middle" font-family="Inter, system-ui, sans-serif" font-size="14" font-weight="600" fill="#1a1a1a">Ledger</text>
          <text x="150" y="414" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="10" fill="#6b6b6b">proof</text>
        </g>

        <!-- Messy squiggle input (appears at step 7) -->
        <path id="squiggle" d="M 10,100 Q 25,80 35,100 Q 45,120 55,100 Q 65,80 75,100 Q 85,120 95,100" stroke="#cc3333" stroke-width="2.5" fill="none" stroke-linecap="round" opacity="0" />

        <!-- Blue AI perception filter bar (step 8) -->
        <g id="ai-filter" opacity="0">
          <rect x="96" y="70" width="8" height="60" rx="4" fill="#2563eb" opacity="0.7" />
          <text x="100" y="60" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="8" fill="#2563eb">AI</text>
        </g>

        <!-- AI optimization pulse around person (step 9) -->
        <circle id="ai-opt-ring-a" cx="650" cy="400" r="58" fill="none" stroke="#2563eb" stroke-width="3" stroke-dasharray="4 3" opacity="0" />
        <circle id="ai-opt-ring-b" cx="720" cy="310" r="36" fill="none" stroke="#2563eb" stroke-width="2" stroke-dasharray="4 3" opacity="0" />
        <circle id="ai-opt-ring-c" cx="750" cy="400" r="36" fill="none" stroke="#2563eb" stroke-width="2" stroke-dasharray="4 3" opacity="0" />
        <!-- "BEST" label on selected person -->
        <text id="ai-best-label" x="650" y="360" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="9" font-weight="700" fill="#2563eb" opacity="0">BEST MATCH</text>

        <!-- AI pattern detection: ledger lines + arc back to policy (step 10) -->
        <g id="ai-ledger-lines" opacity="0">
          <line x1="120" y1="385" x2="180" y2="385" stroke="#2563eb" stroke-width="1" opacity="0.5" />
          <line x1="125" y1="392" x2="175" y2="392" stroke="#2563eb" stroke-width="1" opacity="0.5" />
          <line x1="122" y1="399" x2="178" y2="399" stroke="#2563eb" stroke-width="1" opacity="0.5" />
          <line x1="128" y1="406" x2="172" y2="406" stroke="#2563eb" stroke-width="1" opacity="0.5" />
          <line x1="124" y1="413" x2="176" y2="413" stroke="#2563eb" stroke-width="1" opacity="0.5" />
        </g>
        <circle id="ai-pattern-ring" cx="150" cy="400" r="58" fill="none" stroke="#2563eb" stroke-width="3" stroke-dasharray="4 3" opacity="0" />
        <!-- Arc from Ledger to Policy = "pattern suggests new rule" -->
        <path id="ai-suggestion-arc" d="M 185,360 Q 280,250 365,140" stroke="#2563eb" stroke-width="2" stroke-dasharray="6 3" fill="none" opacity="0" />
        <polygon id="ai-suggestion-arrow" points="360,145 370,135 365,150" fill="#2563eb" opacity="0" />
        <text id="ai-suggestion-label" x="260" y="240" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="9" fill="#2563eb" opacity="0" transform="rotate(-35, 260, 240)">pattern → new rule?</text>

        <!-- AI perception ring for Event (step 8) -->
        <circle id="ai-perception-ring" cx="150" cy="100" r="58" fill="none" stroke="#2563eb" stroke-width="3" stroke-dasharray="4 3" opacity="0" />

        <!-- Final state: all AI rings at edges (step 11) -->
        <text id="ai-label" x="400" y="265" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="13" font-weight="600" fill="#2563eb" opacity="0">AI LAYER</text>

        <!-- The dot (flows through the system) -->
        <circle id="dot" cx="150" cy="100" r="6" fill="#1a1a1a" opacity="0" />

        <!-- Clean dot that emerges from AI filter (step 8) -->
        <circle id="clean-dot" cx="150" cy="100" r="6" fill="#2563eb" opacity="0" />

      </svg>
    </div>

    <!-- Scroll steps -->
    <div class="steps">
      <div class="step" data-step="0">
        <div class="step-content">
          <p class="step-label">Scroll to begin</p>
        </div>
      </div>

      <div class="step" data-step="1">
        <div class="step-content">
          <h2>Something happened.</h2>
          <p>An event fires. But it just sits there. Nothing knows what to do with it.</p>
          <div class="examples">
            <div class="example"><span class="example-label">Property</span> Homeowner reports a leak</div>
            <div class="example"><span class="example-label">Landscaping</span> Customer books a mow</div>
            <div class="example"><span class="example-label">ER</span> Patient walks through the door</div>
          </div>
        </div>
      </div>

      <div class="step" data-step="2">
        <div class="step-content">
          <h2>Now there's a rule.</h2>
          <p>A policy decides what happens next — who's eligible, what's allowed, what the constraints are.</p>
          <div class="examples">
            <div class="example"><span class="example-label">Property</span> Water leak = emergency. 2-hour SLA. Notify owner.</div>
            <div class="example"><span class="example-label">Landscaping</span> Match crew by zone, rating, and availability</div>
            <div class="example"><span class="example-label">ER</span> Triage: ESI Level 2. See within 10 minutes.</div>
          </div>
        </div>
      </div>

      <div class="step" data-step="3">
        <div class="step-content">
          <h2>Now there's a how.</h2>
          <p>Steps materialize. First this, then that. In order. With gates.</p>
          <div class="examples">
            <div class="example"><span class="example-label">Property</span> Dispatch plumber. Confirm arrival. Document repair. Close.</div>
            <div class="example"><span class="example-label">Landscaping</span> Arrive. Assess. Mow. Edge. Blow. Photo. Complete.</div>
            <div class="example"><span class="example-label">ER</span> Vitals. History. Assessment. Orders. Reassess.</div>
          </div>
        </div>
      </div>

      <div class="step" data-step="4">
        <div class="step-content">
          <h2>Now someone's accountable.</h2>
          <p>Not just anyone — someone qualified, available, and assigned by policy.</p>
          <div class="examples">
            <div class="example"><span class="example-label">Property</span> Licensed plumber, within 15 miles, rated 4.5+</div>
            <div class="example"><span class="example-label">Landscaping</span> Crew lead certified for this property size</div>
            <div class="example"><span class="example-label">ER</span> Attending physician, on shift, credentialed for trauma</div>
          </div>
        </div>
      </div>

      <div class="step" data-step="5">
        <div class="step-content">
          <h2>Now there's a thing.</h2>
          <p>The asset — with identity, state, and history that persists across every event.</p>
          <div class="examples">
            <div class="example"><span class="example-label">Property</span> Unit 4B kitchen — water heater, installed 2019, last inspected 7 months ago</div>
            <div class="example"><span class="example-label">Landscaping</span> 1247 Oak St — bermuda grass, 0.3 acres, last service 12 days ago</div>
            <div class="example"><span class="example-label">ER</span> Bed 7 — patient, 58M, chest pain, prior cardiac history</div>
          </div>
        </div>
      </div>

      <div class="step" data-step="6">
        <div class="step-content">
          <h2>Now there's proof.</h2>
          <p>The ledger records everything. Who did what, when, what they found. Append-only. Immutable.</p>
          <p>The record feeds back into future decisions.</p>
          <div class="examples">
            <div class="example"><span class="example-label">Property</span> Plumber arrived 10:42am. Fixed supply line. Photos attached. Cost: $340.</div>
            <div class="example"><span class="example-label">Landscaping</span> Service complete 2:15pm. Before/after photos. Crew rating: 4.8.</div>
            <div class="example"><span class="example-label">ER</span> Troponin negative. Discharged 14:30. Follow-up scheduled. Full chart documented.</div>
          </div>
          <p class="finale">Six primitives. Always six.</p>
        </div>
      </div>

      <div class="step" data-step="7">
        <div class="step-content ai-step">
          <h2>But the real world is messy.</h2>
          <p>The event arrives as a photo. A voice note. A vague text. The system can't route a squiggle.</p>
          <div class="examples">
            <div class="example"><span class="example-label">Property</span> "there's water coming from somewhere upstairs"</div>
            <div class="example"><span class="example-label">Landscaping</span> Blurry photo of overgrown yard, no address</div>
            <div class="example"><span class="example-label">ER</span> "my chest feels weird" — no vitals, no history</div>
          </div>
        </div>
      </div>

      <div class="step" data-step="8">
        <div class="step-content ai-step">
          <p class="ai-badge">AI MODE 1 — PERCEPTION</p>
          <h2>AI sees.</h2>
          <p>A thin blue layer between the mess and the system. The squiggle passes through — comes out structured. The system hums again.</p>
          <div class="examples">
            <div class="example"><span class="example-label">Property</span> Photo → water damage, ceiling, severity: high, unit: 4B</div>
            <div class="example"><span class="example-label">Landscaping</span> GPS + photo → 1247 Oak St, overgrowth grade: heavy</div>
            <div class="example"><span class="example-label">ER</span> Intake transcript → chest pain, 58M, onset 2hrs, no prior meds</div>
          </div>
        </div>
      </div>

      <div class="step" data-step="9">
        <div class="step-content ai-step">
          <p class="ai-badge">AI MODE 2 — OPTIMIZATION</p>
          <h2>Three people can do the work.</h2>
          <p>Policy already filtered who's eligible. AI picks who's optimal — fastest, closest, least loaded. Policy decides who <em>can</em>. AI decides who <em>should</em>.</p>
          <div class="examples">
            <div class="example"><span class="example-label">Property</span> 3 plumbers qualified → AI picks one: 4.8 rating, 3 miles, available now</div>
            <div class="example"><span class="example-label">Landscaping</span> 2 crews in zone → resequence routes, save 40 min</div>
            <div class="example"><span class="example-label">ER</span> 4 attendings on shift → assign by current acuity load</div>
          </div>
        </div>
      </div>

      <div class="step" data-step="10">
        <div class="step-content ai-step">
          <p class="ai-badge">AI MODE 3 — PATTERN DETECTION</p>
          <h2>AI reads the record.</h2>
          <p>The ledger has been filling up. AI scans it — finds what humans can't see. Recurring failures. Drifting SLAs. Procedures that stall at step 3. It proposes. Humans decide.</p>
          <div class="examples">
            <div class="example"><span class="example-label">Property</span> Unit 4B: 3rd water event in 14 months → recommend pipe replacement</div>
            <div class="example"><span class="example-label">Landscaping</span> Crew B: 22% slower on similar lots → flag for review</div>
            <div class="example"><span class="example-label">ER</span> Door-to-doc trending up 12% over 6 weeks → staffing model alert</div>
          </div>
        </div>
      </div>

      <div class="step" data-step="11">
        <div class="step-content">
          <h2>Structure first. Intelligence second.</h2>
          <p>The six primitives are the brain. AI is the senses — at the edges, never the center. Thin, bounded, replaceable.</p>
          <p class="finale">The brain is rules. The senses are AI. The record is proof.</p>
          <div class="links">
            <a href="/">Principles</a>
            <a href="/essays">Essays</a>
            <a href="/glossary">Glossary</a>
            <a href="/architect">The Role</a>
          </div>
        </div>
      </div>

    </div>
  </div>
</Base>

<style>
  .explain {
    position: relative;
  }

  .graphic {
    position: sticky;
    top: 0;
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1;
  }

  #diagram {
    width: 100%;
    max-width: 800px;
    padding: 2rem;
  }

  .steps {
    position: relative;
    z-index: 2;
    pointer-events: none;
  }

  .step {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 2rem;
  }

  .step-content {
    max-width: 380px;
    background: rgba(250, 250, 248, 0.95);
    backdrop-filter: blur(8px);
    border: 1px solid #e5e5e3;
    border-radius: 12px;
    padding: 2rem;
    pointer-events: auto;
  }

  .step-content h2 {
    font-size: 1.5rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin-bottom: 0.75rem;
    color: #1a1a1a;
  }

  .step-content p {
    color: #6b6b6b;
    line-height: 1.7;
    margin-bottom: 0.75rem;
    font-size: 0.95rem;
  }

  .step-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.85rem;
    color: #2563eb;
  }

  .examples {
    margin-top: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .example {
    font-size: 0.8rem;
    color: #6b6b6b;
    line-height: 1.5;
    padding-left: 0.75rem;
    border-left: 2px solid #e5e5e3;
  }

  .example-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem;
    font-weight: 500;
    color: #2563eb;
    display: block;
    margin-bottom: 0.1rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .finale {
    font-weight: 600;
    color: #1a1a1a !important;
    margin-top: 1rem;
  }

  .ai-step {
    border-color: #2563eb;
    border-width: 2px;
  }

  .ai-step .example {
    border-left-color: #2563eb;
  }

  .ai-badge {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem !important;
    font-weight: 600;
    color: #2563eb !important;
    letter-spacing: 0.1em;
    margin-bottom: 0.25rem !important;
  }

  .links {
    display: flex;
    gap: 1.5rem;
    margin-top: 1.5rem;
    flex-wrap: wrap;
  }

  .links a {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    color: #2563eb;
    text-decoration: none;
    pointer-events: auto;
  }

  .links a:hover {
    text-decoration: underline;
  }

  @keyframes pulse-ring {
    0%, 100% { opacity: 0.3; }
    50% { opacity: 1; }
  }

  .ai-glow {
    animation: pulse-ring 2s ease-in-out infinite;
  }

  @keyframes squiggle-shake {
    0%, 100% { transform: translateX(0); }
    25% { transform: translateX(-3px); }
    75% { transform: translateX(3px); }
  }

  .squiggle-animate {
    animation: squiggle-shake 0.3s ease-in-out infinite;
  }

  @keyframes dim-node {
    0%, 100% { opacity: 0.3; }
  }

  .node {
    transition: opacity 0.8s ease;
  }

  #dot, #clean-dot {
    transition: opacity 0.5s ease;
  }

  line, polygon, path, rect {
    transition: opacity 0.6s ease;
  }
</style>

<script>
  const steps = document.querySelectorAll('.step');
  let currentStep = 0;

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const step = parseInt((entry.target as HTMLElement).dataset.step || '0');
        if (step !== currentStep) {
          currentStep = step;
          updateDiagram(step);
        }
      }
    });
  }, {
    threshold: 0.5
  });

  steps.forEach(step => observer.observe(step));

  function show(id: string, visible: boolean) {
    const el = document.getElementById(id);
    if (el) el.style.opacity = visible ? '1' : '0';
  }

  function toggleClass(id: string, cls: string, on: boolean) {
    const el = document.getElementById(id);
    if (el) {
      if (on) el.classList.add(cls);
      else el.classList.remove(cls);
    }
  }

  let dotAnimation: number | null = null;

  function stopDot() {
    if (dotAnimation) {
      cancelAnimationFrame(dotAnimation);
      dotAnimation = null;
    }
  }

  function updateDiagram(step: number) {
    // === ACT 1: The Six Primitives ===

    // Step 1: Event
    show('node-event', step >= 1);

    // Static dot at Event for steps 1-5
    if (step >= 1 && step < 6) {
      stopDot();
      show('dot', true);
      show('clean-dot', false);
      const dot = document.getElementById('dot');
      if (dot) {
        dot.setAttribute('cx', '150');
        dot.setAttribute('cy', '100');
        dot.setAttribute('fill', '#1a1a1a');
      }
    }

    // Step 2: Policy + path
    show('node-policy', step >= 2);
    show('path-event-policy', step >= 2);
    show('arrow-1', step >= 2);

    // Step 3: Procedure + path
    show('node-procedure', step >= 3);
    show('path-policy-procedure', step >= 3);
    show('arrow-2', step >= 3);

    // Step 4: Person + path
    show('node-person', step >= 4);
    show('path-procedure-person', step >= 4);
    show('arrow-3', step >= 4);

    // Step 5: Asset + path
    show('node-asset', step >= 5);
    show('path-person-asset', step >= 5);
    show('arrow-4', step >= 5);

    // Step 6: Ledger + remaining paths + loop animation
    show('node-ledger', step >= 6);
    show('path-asset-ledger', step >= 6);
    show('arrow-5', step >= 6);
    show('path-ledger-event', step >= 6);
    show('arrow-6', step >= 6);

    if (step === 6) {
      show('dot', true);
      const dot = document.getElementById('dot');
      if (dot) dot.setAttribute('fill', '#1a1a1a');
      animateDot(false);
    }

    // === ACT 2: The AI Layer ===

    // Step 7: The mess — squiggle appears, system breaks
    show('squiggle', step === 7);
    toggleClass('squiggle', 'squiggle-animate', step === 7);
    if (step === 7) {
      // Dot stops, system stalled
      stopDot();
      show('dot', false);
      show('clean-dot', false);
    }

    // Step 8: Perception — blue filter cleans the squiggle
    show('ai-filter', step >= 8 && step <= 11);
    show('ai-perception-ring', step >= 8 && step <= 11);
    toggleClass('ai-perception-ring', 'ai-glow', step === 8);
    show('squiggle', step === 7); // squiggle gone after 7
    if (step === 8) {
      // Clean blue dot emerges, system flows again
      show('dot', false);
      show('clean-dot', true);
      animateDot(true);
    }

    // Step 9: Optimization — three person nodes, AI picks best
    show('node-person-b', step === 9);
    show('node-person-c', step === 9);
    show('ai-opt-ring-a', step === 9);
    show('ai-opt-ring-b', step === 9);
    show('ai-opt-ring-c', step === 9);
    show('ai-best-label', step === 9);
    toggleClass('ai-opt-ring-a', 'ai-glow', step === 9);
    if (step === 9) {
      // Dim the non-selected persons
      const pb = document.getElementById('node-person-b');
      const pc = document.getElementById('node-person-c');
      if (pb) pb.style.opacity = '0.4';
      if (pc) pc.style.opacity = '0.4';
      show('clean-dot', true);
      animateDot(true);
    }

    // Step 10: Pattern Detection — ledger glows, arc to policy
    show('ai-ledger-lines', step >= 10 && step <= 11);
    show('ai-pattern-ring', step >= 10 && step <= 11);
    show('ai-suggestion-arc', step >= 10 && step <= 11);
    show('ai-suggestion-arrow', step >= 10 && step <= 11);
    show('ai-suggestion-label', step >= 10 && step <= 11);
    toggleClass('ai-pattern-ring', 'ai-glow', step === 10);
    toggleClass('ai-ledger-lines', 'ai-glow', step === 10);
    if (step === 10) {
      show('clean-dot', true);
      animateDot(true);
    }

    // Step 11: Complete system — everything visible, all AI at edges
    if (step === 11) {
      // All primitives visible (already are from step 6+)
      // AI rings visible but not pulsing
      show('ai-perception-ring', true);
      show('ai-pattern-ring', true);
      show('ai-filter', true);
      show('ai-label', true);
      show('ai-ledger-lines', true);
      show('ai-suggestion-arc', true);
      show('ai-suggestion-arrow', true);
      show('ai-suggestion-label', true);

      // Hide extra persons (back to single person node)
      show('node-person-b', false);
      show('node-person-c', false);
      show('ai-opt-ring-a', false);
      show('ai-opt-ring-b', false);
      show('ai-opt-ring-c', false);
      show('ai-best-label', false);

      // Remove all pulses
      ['ai-perception-ring', 'ai-pattern-ring', 'ai-ledger-lines'].forEach(id => {
        toggleClass(id, 'ai-glow', false);
      });

      show('clean-dot', true);
      animateDot(true);
    }

    // Hide AI stuff for primitive-only steps
    if (step < 7) {
      show('squiggle', false);
      show('ai-filter', false);
      show('ai-perception-ring', false);
      show('clean-dot', false);
      show('node-person-b', false);
      show('node-person-c', false);
      show('ai-opt-ring-a', false);
      show('ai-opt-ring-b', false);
      show('ai-opt-ring-c', false);
      show('ai-best-label', false);
      show('ai-ledger-lines', false);
      show('ai-pattern-ring', false);
      show('ai-suggestion-arc', false);
      show('ai-suggestion-arrow', false);
      show('ai-suggestion-label', false);
      show('ai-label', false);
    }
  }

  function animateDot(useBlue: boolean) {
    const dotId = useBlue ? 'clean-dot' : 'dot';
    const dot = document.getElementById(dotId);
    if (!dot) return;

    // Hide the other dot
    show(useBlue ? 'dot' : 'clean-dot', false);

    // Full loop: Event -> Policy -> Procedure -> Person -> Asset -> Ledger -> Event
    const waypoints = [
      { x: 150, y: 100 },  // Event
      { x: 400, y: 100 },  // Policy
      { x: 650, y: 100 },  // Procedure
      { x: 650, y: 400 },  // Person
      { x: 400, y: 400 },  // Asset
      { x: 150, y: 400 },  // Ledger
      { x: 150, y: 100 },  // Back to Event
    ];

    let wpIndex = 0;
    let progress = 0;
    const speed = 0.015;

    stopDot();

    function frame() {
      progress += speed;

      if (progress >= 1) {
        progress = 0;
        wpIndex++;
        if (wpIndex >= waypoints.length - 1) {
          wpIndex = 0;
        }
      }

      const from = waypoints[wpIndex];
      const to = waypoints[wpIndex + 1];

      const x = from.x + (to.x - from.x) * progress;
      const y = from.y + (to.y - from.y) * progress;

      dot.setAttribute('cx', String(x));
      dot.setAttribute('cy', String(y));

      dotAnimation = requestAnimationFrame(frame);
    }

    frame();
  }
</script>
