<script>
  import scrollama from 'scrollama';

  let currentStep = 0;

  const scroller = scrollama();
  scroller.setup({
    step: '.step',
    offset: 0.5,
  }).onStepEnter(({ index }: { index: number }) => {
    const step = index;
    if (step !== currentStep) {
      currentStep = step;
      updateDiagram(step);
    }
  });

  window.addEventListener('resize', () => scroller.resize());

  function show(id: string, visible: boolean) {
    const el = document.getElementById(id);
    if (el) el.style.opacity = visible ? '1' : '0';
  }

  let dotAnimation: number | null = null;
  let stepTimeouts: ReturnType<typeof setTimeout>[] = [];

  function stopDot() {
    if (dotAnimation) {
      cancelAnimationFrame(dotAnimation);
      dotAnimation = null;
    }
  }

  // Hide all diagram elements to start clean
  function hideAll() {
    // Primitives
    ['node-event', 'node-policy', 'node-procedure', 'node-person', 'node-asset', 'node-ledger'].forEach(id => show(id, false));
    // Paths + arrows
    ['path-event-policy', 'path-policy-procedure', 'path-procedure-person', 'path-person-asset', 'path-asset-ledger'].forEach(id => show(id, false));
    ['arrow-1', 'arrow-2', 'arrow-3', 'arrow-4', 'arrow-5'].forEach(id => show(id, false));
    // Dots
    show('dot', false);
    show('clean-dot', false);
    stopDot();
    // AI announce
    show('ai-announce', false);
    const announceEl = document.getElementById('ai-announce');
    if (announceEl) announceEl.style.transform = 'translate(0,0) scale(1)';
    // AI elements
    show('chaos-flood', false);
    show('ai-filter', false);
    show('node-person-b', false);
    show('node-person-c', false);
    show('ai-opt-highlight', false);
    show('ai-best-label', false);
    show('ai-best-badge-bg', false);
    show('ai-ledger-lines', false);
    show('ai-pattern-line', false);
    show('ai-pattern-label', false);
    show('ai-edge-labels', false);
    // Reset ledger scan lines
    document.querySelectorAll('.ledger-scan-line').forEach(el => (el as HTMLElement).style.opacity = '0');
    // Clear any pending step timeouts
    stepTimeouts.forEach(t => clearTimeout(t));
    stepTimeouts = [];
    // Bookend elements
    show('ai-blob', false);
    show('comparison', false);
  }

  function announceAI(label: string, targetX: number, targetY: number, callback: () => void) {
    const group = document.getElementById('ai-announce');
    const text = document.getElementById('ai-announce-text');
    if (!group || !text) { callback(); return; }

    text.textContent = label;
    // Reset to center, full size
    group.style.transition = 'none';
    group.style.transform = 'translate(0,0) scale(1)';
    group.style.opacity = '1';
    // Force reflow so the reset takes effect before transition
    group.getBoundingClientRect();

    // After a pause, fly to target
    stepTimeouts.push(setTimeout(() => {
      group.style.transition = 'transform 0.8s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.8s ease';
      const dx = targetX - 400;
      const dy = targetY - 250;
      group.style.transform = `translate(${dx}px, ${dy}px) scale(0.4)`;
      group.style.opacity = '0';
    }, 1200));

    // After fly completes, clean up and run callback
    stepTimeouts.push(setTimeout(() => {
      group.style.transition = 'none';
      group.style.opacity = '0';
      group.style.transform = 'translate(0,0) scale(1)';
      callback();
    }, 2050));
  }

  function updateDiagram(step: number) {
    // Reset everything, then build up
    hideAll();

    // === Step 0: Blue AI blob opener ===
    if (step === 0) {
      show('ai-blob', true);
      return;
    }

    // === Step 12: Two architectures comparison ===
    if (step === 12) {
      show('comparison', true);
      return;
    }

    // === ACT 1: The Six Primitives (steps 1-6) ===

    // Step 1+: Event
    show('node-event', step >= 1);

    // Static dot at Event for steps 1-5
    if (step >= 1 && step < 6) {
      show('dot', true);
      show('clean-dot', false);
      const dot = document.getElementById('dot');
      if (dot) {
        dot.setAttribute('cx', '150');
        dot.setAttribute('cy', '100');
        dot.setAttribute('fill', '#1a1a1a');
        dot.setAttribute('r', '6');
      }
    }

    // Step 2+: Policy + path
    show('node-policy', step >= 2);
    show('path-event-policy', step >= 2);
    show('arrow-1', step >= 2);

    // Step 3+: Procedure + path
    show('node-procedure', step >= 3);
    show('path-policy-procedure', step >= 3);
    show('arrow-2', step >= 3);

    // Step 4+: Person + path
    show('node-person', step >= 4);
    show('path-procedure-person', step >= 4);
    show('arrow-3', step >= 4);

    // Step 5+: Asset + path
    show('node-asset', step >= 5);
    show('path-person-asset', step >= 5);
    show('arrow-4', step >= 5);

    // Step 6+: Ledger + remaining paths + loop animation
    show('node-ledger', step >= 6);
    show('path-asset-ledger', step >= 6);
    show('arrow-5', step >= 6);

    if (step === 6) {
      show('dot', true);
      const dot = document.getElementById('dot');
      if (dot) dot.setAttribute('fill', '#1a1a1a');
      animateDot(false);
    }

    // === ACT 2: The AI Layer (steps 7-11) ===

    // Step 7: The mess — chaos flood appears, system breaks
    show('chaos-flood', step === 7);
    if (step === 7) {
      stopDot();
    }

    // Step 8: Perception — announce then filter bar + dot
    if (step >= 8 && step <= 11 && step !== 8) {
      show('ai-filter', true);
    }
    if (step === 8) {
      announceAI('PERCEPTION', 100, 100, () => {
        show('ai-filter', true);
        show('clean-dot', true);
        animateDot(true);
      });
    }

    // Step 9: Optimization — announce then staggered person reveal
    if (step === 9) {
      announceAI('OPTIMIZATION', 650, 400, () => {
        show('ai-opt-highlight', true);
        show('clean-dot', true);
        animateDot(true);
        // Stagger: B appears, then main Person, then C
        const pb = document.getElementById('node-person-b');
        const person = document.getElementById('node-person');
        const pc = document.getElementById('node-person-c');
        if (pb) pb.style.opacity = '0';
        if (pc) pc.style.opacity = '0';
        stepTimeouts.push(setTimeout(() => { if (pb) pb.style.opacity = '1'; }, 0));
        stepTimeouts.push(setTimeout(() => { if (person) person.style.opacity = '1'; }, 200));
        stepTimeouts.push(setTimeout(() => { if (pc) pc.style.opacity = '1'; }, 400));
        // After all appear, sweep highlight bar and reveal winner
        stepTimeouts.push(setTimeout(() => {
          const sweep = document.getElementById('ai-sweep-bar');
          if (sweep) {
            sweep.style.transition = 'width 0.5s ease';
            sweep.setAttribute('width', '240');
          }
        }, 800));
        stepTimeouts.push(setTimeout(() => {
          show('ai-best-label', true);
          show('ai-best-badge-bg', true);
          if (pb) pb.style.opacity = '0.3';
          if (pc) pc.style.opacity = '0.3';
        }, 1300));
      });
    } else {
      show('node-person-b', false);
      show('node-person-c', false);
    }

    // Step 10: Pattern Detection — announce then ledger scan
    show('ai-ledger-lines', step >= 10 && step <= 11);
    if (step === 10) {
      announceAI('PATTERN', 150, 400, () => {
        show('clean-dot', true);
        animateDot(true);
        // Stagger ledger scan lines
        const scanLines = document.querySelectorAll('.ledger-scan-line');
        scanLines.forEach((line, i) => {
          stepTimeouts.push(setTimeout(() => {
            (line as HTMLElement).style.opacity = '1';
          }, i * 100));
        });
        // After scanning, show horizontal line and label
        stepTimeouts.push(setTimeout(() => {
          show('ai-pattern-line', true);
          show('ai-pattern-label', true);
        }, scanLines.length * 100 + 200));
      });
    }

    // Step 11: Complete system — AI text labels at three edge points
    if (step === 11) {
      show('ai-filter', true);
      show('ai-edge-labels', true);
      show('ai-ledger-lines', true);
      show('ai-pattern-line', true);
      show('ai-pattern-label', true);
      // Make ledger scan lines fully visible
      document.querySelectorAll('.ledger-scan-line').forEach(el => (el as HTMLElement).style.opacity = '1');

      show('clean-dot', true);
      animateDot(true);
    }
  }

  // Easing function: ease-in-out cubic
  function easeInOut(t: number): number {
    return t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2;
  }

  function animateDot(useBlue: boolean) {
    const dotId = useBlue ? 'clean-dot' : 'dot';
    const dot = document.getElementById(dotId);
    if (!dot) return;

    // Hide the other dot
    show(useBlue ? 'dot' : 'clean-dot', false);

    // One pass: Event -> Policy -> Procedure -> Person -> Asset -> Ledger (no loop back)
    const waypoints = [
      { x: 150, y: 100 },  // Event
      { x: 400, y: 100 },  // Policy
      { x: 650, y: 100 },  // Procedure
      { x: 650, y: 400 },  // Person
      { x: 400, y: 400 },  // Asset
      { x: 150, y: 400 },  // Ledger
    ];

    let wpIndex = 0;
    let progress = 0;
    const speed = 0.012;
    const dwellDuration = 18; // frames to dwell at each node (~300ms at 60fps)
    let dwellCounter = 0;
    let isDwelling = false;
    const baseRadius = 6;

    stopDot();

    function frame() {
      if (isDwelling) {
        // Pulse: scale up slightly during dwell
        const dwellProgress = dwellCounter / dwellDuration;
        const pulseScale = 1 + 0.4 * Math.sin(dwellProgress * Math.PI);
        dot.setAttribute('r', String(baseRadius * pulseScale));
        dwellCounter++;
        if (dwellCounter >= dwellDuration) {
          isDwelling = false;
          dwellCounter = 0;
          dot.setAttribute('r', String(baseRadius));
          // Move to next segment or stop at end
          wpIndex++;
          if (wpIndex >= waypoints.length - 1) {
            // Stay at Ledger — don't loop
            return;
          }
          progress = 0;
        }
        dotAnimation = requestAnimationFrame(frame);
        return;
      }

      progress += speed;

      if (progress >= 1) {
        // Snap to waypoint and start dwell
        const target = waypoints[wpIndex + 1] || waypoints[0];
        dot.setAttribute('cx', String(target.x));
        dot.setAttribute('cy', String(target.y));
        progress = 1;
        isDwelling = true;
        dwellCounter = 0;
        dotAnimation = requestAnimationFrame(frame);
        return;
      }

      const from = waypoints[wpIndex];
      const to = waypoints[wpIndex + 1] || waypoints[0];

      // Apply ease-in-out to progress
      const eased = easeInOut(progress);

      const x = from.x + (to.x - from.x) * eased;
      const y = from.y + (to.y - from.y) * eased;

      dot.setAttribute('cx', String(x));
      dot.setAttribute('cy', String(y));

      dotAnimation = requestAnimationFrame(frame);
    }

    frame();
  }

  // Show step 0 immediately on load (Scrollama doesn't fire until scroll)
  updateDiagram(0);
</script>
