        },
        8: {
          structured: 'Audit: emergency dispatch policy conflicts with new vendor onboarding procedure. 3 inspector certifications expire next month.',
          outcome: 'Policy revision queued for review. Recertification reminders sent automatically.',
        },
      },
    },
    restaurant: {
      label: 'Restaurant',
      examples: {
        1: {
          input: 'Server flags cold steak complaint from Table 12.',
