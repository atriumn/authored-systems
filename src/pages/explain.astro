---
import Base from '../layouts/Base.astro';
---

<Base title="How It Works — authored.systems" description="Watch an operation come to life, one primitive at a time.">
  <div class="explain">
    <!-- Sticky graphic -->
    <div class="graphic">
      <svg id="diagram" viewBox="0 0 800 500" xmlns="http://www.w3.org/2000/svg">
        <!-- Grid layout for 6 nodes:
             Event(150,100) -> Policy(400,100) -> Procedure(650,100)
                                                       |
             Ledger(150,400) <- Asset(400,400) <- Person(650,400)
             Ledger feeds back to Policy (dotted)
        -->

        <!-- Paths (hidden initially) -->
        <g id="paths" opacity="0">
          <line x1="210" y1="100" x2="340" y2="100" stroke="#e5e5e3" stroke-width="2" />
          <line x1="460" y1="100" x2="590" y2="100" stroke="#e5e5e3" stroke-width="2" />
          <line x1="650" y1="160" x2="650" y2="340" stroke="#e5e5e3" stroke-width="2" />
          <line x1="590" y1="400" x2="460" y2="400" stroke="#e5e5e3" stroke-width="2" />
          <line x1="340" y1="400" x2="210" y2="400" stroke="#e5e5e3" stroke-width="2" />
          <!-- Feedback loop: Ledger back to Policy -->
          <path d="M 150 340 L 150 250 Q 150 200 200 200 L 340 150" stroke="#e5e5e3" stroke-width="2" fill="none" stroke-dasharray="6 4" opacity="0" id="feedback-path" />
        </g>

        <!-- Arrow heads on paths -->
        <defs>
          <marker id="arrow" markerWidth="8" markerHeight="6" refX="8" refY="3" orient="auto">
            <path d="M0,0 L8,3 L0,6" fill="#e5e5e3" />
          </marker>
          <marker id="arrow-blue" markerWidth="8" markerHeight="6" refX="8" refY="3" orient="auto">
            <path d="M0,0 L8,3 L0,6" fill="#2563eb" />
          </marker>
        </defs>

        <!-- Event node -->
        <g id="node-event" class="node" opacity="0">
          <circle cx="150" cy="100" r="50" fill="none" stroke="#1a1a1a" stroke-width="2" />
          <text x="150" y="96" text-anchor="middle" font-family="Inter, system-ui, sans-serif" font-size="14" font-weight="600" fill="#1a1a1a">Event</text>
          <text x="150" y="114" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="10" fill="#6b6b6b">trigger</text>
        </g>

        <!-- Policy node -->
        <g id="node-policy" class="node" opacity="0">
          <circle cx="400" cy="100" r="50" fill="none" stroke="#1a1a1a" stroke-width="2" />
          <text x="400" y="96" text-anchor="middle" font-family="Inter, system-ui, sans-serif" font-size="14" font-weight="600" fill="#1a1a1a">Policy</text>
          <text x="400" y="114" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="10" fill="#6b6b6b">rule</text>
        </g>

        <!-- Procedure node -->
        <g id="node-procedure" class="node" opacity="0">
          <circle cx="650" cy="100" r="50" fill="none" stroke="#1a1a1a" stroke-width="2" />
          <text x="650" y="96" text-anchor="middle" font-family="Inter, system-ui, sans-serif" font-size="14" font-weight="600" fill="#1a1a1a">Procedure</text>
          <text x="650" y="114" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="10" fill="#6b6b6b">steps</text>
        </g>

        <!-- Person node -->
        <g id="node-person" class="node" opacity="0">
          <circle cx="650" cy="400" r="50" fill="none" stroke="#1a1a1a" stroke-width="2" />
          <text x="650" y="396" text-anchor="middle" font-family="Inter, system-ui, sans-serif" font-size="14" font-weight="600" fill="#1a1a1a">Person</text>
          <text x="650" y="414" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="10" fill="#6b6b6b">who</text>
        </g>

        <!-- Asset node -->
        <g id="node-asset" class="node" opacity="0">
          <circle cx="400" cy="400" r="50" fill="none" stroke="#1a1a1a" stroke-width="2" />
          <text x="400" y="396" text-anchor="middle" font-family="Inter, system-ui, sans-serif" font-size="14" font-weight="600" fill="#1a1a1a">Asset</text>
          <text x="400" y="414" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="10" fill="#6b6b6b">thing</text>
        </g>

        <!-- Ledger node -->
        <g id="node-ledger" class="node" opacity="0">
          <circle cx="150" cy="400" r="50" fill="none" stroke="#1a1a1a" stroke-width="2" />
          <text x="150" y="396" text-anchor="middle" font-family="Inter, system-ui, sans-serif" font-size="14" font-weight="600" fill="#1a1a1a">Ledger</text>
          <text x="150" y="414" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="10" fill="#6b6b6b">proof</text>
        </g>

        <!-- The dot (flows through the system) -->
        <circle id="dot" cx="150" cy="100" r="6" fill="#1a1a1a" opacity="0" />

        <!-- The messy input (squiggle) -->
        <path id="squiggle" d="M 30 100 Q 50 70 60 100 Q 70 130 80 100 Q 90 70 100 100" stroke="#1a1a1a" stroke-width="2" fill="none" opacity="0" />

        <!-- AI perception layer -->
        <g id="ai-perception" opacity="0">
          <rect x="95" y="60" width="10" height="80" rx="5" fill="#2563eb" opacity="0.15" />
        </g>

      </svg>
    </div>

    <!-- Scroll steps -->
    <div class="steps">
      <div class="step" data-step="0">
        <div class="step-content">
          <p class="step-label font-mono text-accent text-sm">Scroll to begin</p>
        </div>
      </div>

      <div class="step" data-step="1">
        <div class="step-content">
          <h2>Something happened.</h2>
          <p>A parent books a birthday party. A sensor trips. A coach calls in sick. Monday hits 8am.</p>
          <p>An event fires. But it just sits there. Nothing knows what to do with it.</p>
        </div>
      </div>

      <div class="step" data-step="2">
        <div class="step-content">
          <h2>Now there's a rule.</h2>
          <p>The event has a path. A policy decides what happens next — who's eligible, what's allowed, what the constraints are.</p>
          <p>But the rule points to... nothing. No steps to follow.</p>
        </div>
      </div>

      <div class="step" data-step="3">
        <div class="step-content">
          <h2>Now there's a how.</h2>
          <p>Steps materialize. First this, then that. In order. With gates. The event flows through a defined procedure.</p>
          <p>But no one's doing it.</p>
        </div>
      </div>

      <div class="step" data-step="4">
        <div class="step-content">
          <h2>Now someone's accountable.</h2>
          <p>A person picks up the work. Not just anyone — someone qualified, available, and assigned by policy.</p>
          <p>But what are they working on?</p>
        </div>
      </div>

      <div class="step" data-step="5">
        <div class="step-content">
          <h2>Now there's a thing.</h2>
          <p>The warped wall. The water heater. The customer account. The asset — the thing being acted on, with state that matters.</p>
          <p>But did it happen?</p>
        </div>
      </div>

      <div class="step" data-step="6">
        <div class="step-content">
          <h2>Now there's proof.</h2>
          <p>The ledger records everything. Who did what, when, what they found. Append-only. Immutable. The record feeds back into future decisions.</p>
          <p class="font-semibold mt-4">Six primitives. Always six.</p>
        </div>
      </div>

    </div>
  </div>
</Base>

<style>
  .explain {
    position: relative;
  }

  .graphic {
    position: sticky;
    top: 0;
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1;
  }

  #diagram {
    width: 100%;
    max-width: 800px;
    padding: 2rem;
  }

  .steps {
    position: relative;
    z-index: 2;
    pointer-events: none;
  }

  .step {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 2rem;
  }

  .step-content {
    max-width: 360px;
    background: rgba(250, 250, 248, 0.92);
    backdrop-filter: blur(8px);
    border: 1px solid #e5e5e3;
    border-radius: 12px;
    padding: 2rem;
    pointer-events: auto;
  }

  .step-content h2 {
    font-size: 1.5rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin-bottom: 0.75rem;
    color: #1a1a1a;
  }

  .step-content p {
    color: #6b6b6b;
    line-height: 1.7;
    margin-bottom: 0.5rem;
  }

  .node {
    transition: opacity 0.8s ease;
  }

  #dot {
    transition: opacity 0.5s ease;
  }
</style>

<script>
  const steps = document.querySelectorAll('.step');
  let currentStep = 0;

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const step = parseInt(entry.target.dataset.step);
        if (step !== currentStep) {
          currentStep = step;
          updateDiagram(step);
        }
      }
    });
  }, {
    threshold: 0.5
  });

  steps.forEach(step => observer.observe(step));

  function updateDiagram(step: number) {
    // Step 1: Event appears
    const event = document.getElementById('node-event');
    const dot = document.getElementById('dot');
    if (event) event.style.opacity = step >= 1 ? '1' : '0';
    if (dot) {
      dot.style.opacity = step >= 1 ? '1' : '0';
      dot.setAttribute('cx', '150');
      dot.setAttribute('cy', '100');
    }

    // Step 2: Policy appears, path connects
    const policy = document.getElementById('node-policy');
    const paths = document.getElementById('paths');
    if (policy) policy.style.opacity = step >= 2 ? '1' : '0';
    if (paths) paths.style.opacity = step >= 2 ? '1' : '0';

    // Step 3: Procedure appears
    const procedure = document.getElementById('node-procedure');
    if (procedure) procedure.style.opacity = step >= 3 ? '1' : '0';

    // Step 4: Person appears
    const person = document.getElementById('node-person');
    if (person) person.style.opacity = step >= 4 ? '1' : '0';

    // Step 5: Asset appears
    const asset = document.getElementById('node-asset');
    if (asset) asset.style.opacity = step >= 5 ? '1' : '0';

    // Step 6: Ledger appears, system is complete
    const ledger = document.getElementById('node-ledger');
    const feedback = document.getElementById('feedback-path');
    if (ledger) ledger.style.opacity = step >= 6 ? '1' : '0';
    if (feedback) feedback.style.opacity = step >= 6 ? '1' : '0';

    // Animate dot through the system when all 6 are present
    if (step >= 6 && dot) {
      animateDot();
    }
  }

  let dotAnimation: number | null = null;

  function animateDot() {
    const dot = document.getElementById('dot');
    if (!dot) return;

    // Path: Event -> Policy -> Procedure -> Person -> Asset -> Ledger
    const waypoints = [
      { x: 150, y: 100 },  // Event
      { x: 400, y: 100 },  // Policy
      { x: 650, y: 100 },  // Procedure
      { x: 650, y: 400 },  // Person
      { x: 400, y: 400 },  // Asset
      { x: 150, y: 400 },  // Ledger
    ];

    let wpIndex = 0;
    let progress = 0;
    const speed = 0.02;

    if (dotAnimation) cancelAnimationFrame(dotAnimation);

    function step() {
      const from = waypoints[wpIndex];
      const to = waypoints[(wpIndex + 1) % waypoints.length];

      progress += speed;

      if (progress >= 1) {
        progress = 0;
        wpIndex = (wpIndex + 1) % waypoints.length;
      }

      const x = from.x + (to.x - from.x) * progress;
      const y = from.y + (to.y - from.y) * progress;

      dot.setAttribute('cx', String(x));
      dot.setAttribute('cy', String(y));

      dotAnimation = requestAnimationFrame(step);
    }

    step();
  }
</script>
